# ── Server ─────────────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=zmen-me-na-neco-nahodneho-a-dlouheho

# ── Admin ──────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=zmen-me-po-prvnim-spusteni

# ── Kontaktní údaje (zobrazí se v patičce a na kontaktní stránce) ──
CONTACT_EMAIL=info@kuchyne-cihovsky.cz
CONTACT_PHONE=+420 000 000 000
CONTACT_ADDRESS=Provozovna, Česká republika
CONTACT_HOURS=Po–Pá 8:00–16:00
INSTAGRAM_URL=https://instagram.com/kuchyne_cihovsky
FACEBOOK_URL=https://facebook.com/kuchyne.cihovsky

# ── E-mail — kontaktní formulář ────────────────────────────────────
# Priorita: pokud vyplníte RESEND_API_KEY, použije se Resend.
# Jinak, pokud vyplníte SMTP_HOST, použije se SMTP.
# Pokud ani jedno, zprávy se jen ukládají do administrace.

# Resend (https://resend.com) — free tier 3000 mailů/měsíc.
# Před použitím ověřte doménu (SPF + DKIM DNS záznamy) v Resend dashboardu.
# MAIL_FROM potom musí být z ověřené domény.
RESEND_API_KEY=

# SMTP (nodemailer) — alternativa k Resendu
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Odesílatel a příjemce (pro obě varianty)
MAIL_FROM="Web Kuchyně Cíhovský <info@kuchyne-cihovsky.cz>"
MAIL_TO=info@kuchyne-cihovsky.cz
