<footer class="site-footer">
  <div class="footer-marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>RUČNÍ VÝROBA</span><span class="marquee-dot">◆</span>
      <span>OD 1998</span><span class="marquee-dot">◆</span>
      <span>KUCHYNĚ NA MÍRU</span><span class="marquee-dot">◆</span>
      <span>DVEŘE</span><span class="marquee-dot">◆</span>
      <span>VESTAVĚNÉ SKŘÍNĚ</span><span class="marquee-dot">◆</span>
      <span>NÁBYTEK</span><span class="marquee-dot">◆</span>
      <span>RUČNÍ VÝROBA</span><span class="marquee-dot">◆</span>
      <span>OD 1998</span><span class="marquee-dot">◆</span>
      <span>KUCHYNĚ NA MÍRU</span><span class="marquee-dot">◆</span>
      <span>DVEŘE</span><span class="marquee-dot">◆</span>
      <span>VESTAVĚNÉ SKŘÍNĚ</span><span class="marquee-dot">◆</span>
      <span>NÁBYTEK</span><span class="marquee-dot">◆</span>
    </div>
  </div>

  <div class="container footer-grid">
    <div class="footer-brand-col">
      <div class="brand brand--footer">
        <span class="brand-mark">C</span>
        <span class="brand-name">Čihovský<span class="brand-sub">/ řemeslo od 1998</span></span>
      </div>
      <p class="muted">Rodinná dílna, která už přes dvě desítky let vyrábí kuchyně, dveře a nábytek na míru. Pro každého klienta osobně.</p>
      <div class="socials">
        <% if (contact.instagram) { %>
          <a href="<%= contact.instagram %>" target="_blank" rel="noopener" aria-label="Instagram" class="social-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        <% } %>
        <% if (contact.facebook) { %>
          <a href="<%= contact.facebook %>" target="_blank" rel="noopener" aria-label="Facebook" class="social-link">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.6-1.6h1.7V3.2C16.5 3.1 15.5 3 14.4 3c-2.4 0-4 1.5-4 4.2v2.6H7.7V13h2.7v8h3.1z"/>
            </svg>
          </a>
        <% } %>
      </div>
    </div>

    <div>
      <h4>Navigace</h4>
      <ul class="footer-links">
        <li><a href="/">Domů</a></li>
        <li><a href="/kuchyne">Kuchyně</a></li>
        <li><a href="/dale-nabizime">Dále nabízíme</a></li>
        <li><a href="/o-nas">O nás</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </div>

    <div>
      <h4>Kuchyně</h4>
      <ul class="footer-links">
        <% categoriesKuchyne.forEach(function(cat){ %>
          <li><a href="/kuchyne/<%= cat.slug %>"><%= cat.name %></a></li>
        <% }); %>
      </ul>
    </div>

    <div>
      <h4>Kontakt</h4>
      <ul class="footer-links footer-contact">
        <li><a href="mailto:<%= contact.email %>"><%= contact.email %></a></li>
        <li><a href="tel:<%= contact.phone.replace(/\s/g, '') %>"><%= contact.phone %></a></li>
        <li class="muted"><%= contact.address %></li>
        <li class="muted"><%= contact.hours %></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom container">
    <span>© <%= new Date().getFullYear() %> Kuchyně Čihovský. Všechna práva vyhrazena.</span>
    <a href="/admin/login" class="admin-link">Interní přístup</a>
  </div>
</footer>
<script src="/js/main.js"></script>
</body>
</html>
