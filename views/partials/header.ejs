<header class="site-header" id="site-header">
  <div class="header-inner">
    <a class="brand" href="/">
      <span class="brand-mark">Č</span>
      <span class="brand-name">Čihovský<span class="brand-sub">Dřevointeriér · Olešník</span></span>
    </a>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="site-nav" aria-label="Hlavní">
      <a href="/" class="<%= path === '/' ? 'active' : '' %>">Domů</a>
      <a href="/kuchyne" class="<%= path && path.startsWith('/kuchyne') ? 'active' : '' %>">Kuchyně</a>
      <a href="/dale-nabizime" class="<%= path && path.startsWith('/dale-nabizime') ? 'active' : '' %>">Dále</a>
      <a href="/o-nas" class="<%= path === '/o-nas' ? 'active' : '' %>">O nás</a>
      <a href="/kontakt" class="<%= path === '/kontakt' ? 'active' : '' %>">Kontakt</a>
    </nav>
    <div class="header-socials">
      <% if (contact.facebook) { %>
        <a href="<%= contact.facebook %>" target="_blank" rel="noopener" aria-label="Facebook" class="header-social">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.6-1.6h1.7V3.2C16.5 3.1 15.5 3 14.4 3c-2.4 0-4 1.5-4 4.2v2.6H7.7V13h2.7v8h3.1z"/></svg>
        </a>
      <% } %>
      <% if (contact.instagram) { %>
        <a href="<%= contact.instagram %>" target="_blank" rel="noopener" aria-label="Instagram" class="header-social">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      <% } %>
    </div>
    <a href="/kontakt" class="header-cta">Poptávka →</a>
  </div>
</header>

<div class="scroll-progress" data-scroll-progress aria-hidden="true"><div class="scroll-progress-bar"></div></div>
