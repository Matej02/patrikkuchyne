      <span class="brand-mark">Č</span>
      <span class="brand-name">Čihovský<span class="brand-sub">Dřevointeriér · Olešník</span></span>
    </a>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="site-nav" aria-label="Hlavní">
      <a href="/" class="<%= path === '/' ? 'active' : '' %>">Domů</a>
      <a href="/kuchyne" class="<%= path && path.startsWith('/kuchyne') ? 'active' : '' %>">Kuchyně</a>
      <a href="/dale-nabizime" class="<%= path && path.startsWith('/dale-nabizime') ? 'active' : '' %>">Dále</a>
      <a href="/o-nas" class="<%= path === '/o-nas' ? 'active' : '' %>">O nás</a>
      <a href="/kontakt" class="<%= path === '/kontakt' ? 'active' : '' %>">Kontakt</a>
    </nav>
    <a href="/kontakt" class="header-cta">Poptávka →</a>
  </div>
</header>
