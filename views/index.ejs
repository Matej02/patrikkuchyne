<%- include('partials/head') %>
<body class="page-home" data-scroll="0">
<%- include('partials/header') %>

<!-- ═══════════════ HERO — CINEMATIC COVER ═══════════════ -->
<section class="hero-cover">
  <div class="hero-cover-bg" aria-hidden="true">
    <img src="/uploads/real-06.jpg" alt="" />
    <div class="hero-cover-gradient"></div>
  </div>

  <div class="hero-cover-card">
    <div class="hero-cover-meta">
      <span class="mono">01 · Dřevointeriér</span>
      <span class="mono">Est. 1998 · Olešník</span>
    </div>

    <h1 class="hero-cover-title" data-word-reveal>
      <span class="word"><span style="animation-delay:0.05s">Kuchyň,</span></span>
      <span class="word"><span style="animation-delay:0.15s">kterou</span></span><br>
      <span class="word"><span style="animation-delay:0.25s">nezavře</span></span>
      <span class="word"><em><span style="animation-delay:0.35s">čas</span></em></span><span class="word"><span style="animation-delay:0.45s">.</span></span>
    </h1>

    <p class="hero-cover-lead" data-reveal>
      Kuchyně, dveře a vestavěný nábytek na míru. Ručně, od základu, po dílu. Bez katalogů, bez zkratek.
    </p>

    <div class="hero-cover-cta" data-reveal>
      <a href="/kontakt" class="btn btn--primary btn--lg">
        <span>Nezávazná poptávka</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <a href="/kuchyne" class="btn-text-cta">
        <span>Realizace</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="hero-cover-foot">
      <div class="hero-cover-signature">
        <strong>Vlastimil Čihovský</strong>
        <span class="mono">Truhlář · dílna v Olešníku</span>
      </div>
      <div class="hero-cover-contact">
        <a href="tel:+420608032103">+420 608 032 103</a>
        <a href="mailto:cihovsky@c-box.cz">cihovsky@c-box.cz</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ CO VYRÁBÍME ═══════════════ -->
<section class="section categories-section">
  <div class="container">
    <div class="section-head-mega">
      <span class="eyebrow">02 · Co vyrábíme</span>
      <h2 class="display-mega">Čtyři světy<br>jednoho <em>řemesla</em>.</h2>
      <p class="section-lead">Kuchyně jsou to hlavní. Ale když si oblíbíte, jak pracujeme, málokdo skončí u nich.</p>
    </div>

    <div class="categories-grid">
      <a class="cat-tile" href="/kuchyne/moderni" data-reveal>
        <% if (featured && featured[1]) { %>
          <img src="/uploads/<%= featured[1].thumb_filename || featured[1].filename %>" alt="Moderní kuchyně" />
        <% } %>
        <div class="cat-tile-overlay"></div>
        <div class="cat-tile-content">
          <span class="cat-tile-num">01 · Kuchyně</span>
          <div>
            <h3 class="cat-tile-title">Moderní<br>kuchyně</h3>
            <p class="cat-tile-desc">Čisté linie, integrované spotřebiče, matné nebo lakované povrchy.</p>
            <span class="cat-tile-arrow">→</span>
          </div>
        </div>
      </a>

      <a class="cat-tile" href="/kuchyne/rustikalni" data-reveal>
        <% if (featured && featured[2]) { %>
          <img src="/uploads/<%= featured[2].thumb_filename || featured[2].filename %>" alt="Rustikální kuchyně" />
        <% } %>
        <div class="cat-tile-overlay"></div>
        <div class="cat-tile-content">
          <span class="cat-tile-num">02 · Kuchyně</span>
          <div>
            <h3 class="cat-tile-title">Rustikální<br>kuchyně</h3>
            <p class="cat-tile-desc">Masiv, ruční patina, tradiční detaily. Kuchyň jako z chalupy po babičce.</p>
            <span class="cat-tile-arrow">→</span>
          </div>
        </div>
      </a>

      <a class="cat-tile" href="/kuchyne/ostruvkove" data-reveal>
        <% if (featured && featured[3]) { %>
          <img src="/uploads/<%= featured[3].thumb_filename || featured[3].filename %>" alt="Ostrůvkové kuchyně" />
        <% } %>
        <div class="cat-tile-overlay"></div>
        <div class="cat-tile-content">
          <span class="cat-tile-num">03 · Kuchyně</span>
          <div>
            <h3 class="cat-tile-title">Ostrůvkové<br>kuchyně</h3>
            <p class="cat-tile-desc">Srdce otevřeného prostoru. Bar, dřez, varný ostrůvek — místo pro sešlost.</p>
            <span class="cat-tile-arrow">→</span>
          </div>
        </div>
      </a>

      <a class="cat-tile" href="/dale-nabizime" data-reveal>
        <% if (featured && featured[7]) { %>
          <img src="/uploads/<%= featured[7].thumb_filename || featured[7].filename %>" alt="Dveře, skříně, nábytek" />
        <% } %>
        <div class="cat-tile-overlay"></div>
        <div class="cat-tile-content">
          <span class="cat-tile-num">04 · Dále</span>
          <div>
            <h3 class="cat-tile-title">Dveře,<br>skříně, nábytek</h3>
            <p class="cat-tile-desc">Dveře do celého bytu, vestavěné skříně, knihovny, komody. Cokoli ze dřeva.</p>
            <span class="cat-tile-arrow">→</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════ NÁŠ PŘÍBĚH — spec sheet místo počítadel ═══════════════ -->
<section class="section story-section">
  <div class="container">
    <div class="story-layout">
      <div class="story-left">
        <span class="eyebrow">03 · Kdo za tím stojí</span>
        <h2 class="display-mega">
          Jeden truhlář.<br>
          Jedna dílna.<br>
          <em>Dvacet sedm</em> let.
        </h2>
        <p class="story-p story-p--big">
          Vlastimil Čihovský otevřel dílnu v Olešníku v roce 1998
          s představou, že kuchyně nemá být skládaná krabice.
        </p>
        <p class="story-p">
          Chodí zaměřit sám. Kreslí sám. Vyrábí sám nebo s jedním učedníkem.
          A když je něco potřeba doladit i po letech — přijde a doladí.
        </p>
        <p class="story-p">
          Bez katalogu. Bez showroomu. Bez zbytečných marketingových fint.
          Jen dřevo, ruce a čas.
        </p>
        <div style="margin-top:32px">
          <a href="/o-nas" class="btn-text-cta">
            <span>Celý příběh</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <div class="story-right">
        <div class="spec-list">
          <div class="spec-item">
            <span class="spec-label">Založeno</span>
            <span class="spec-value">1998</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Sídlo</span>
            <span class="spec-value" style="font-size:1.4rem">Olešník <em>6</em></span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Záruka</span>
            <span class="spec-value">5 <em>let</em></span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Kování</span>
            <span class="spec-value" style="font-size:1.4rem">Blum <em>doživotní</em></span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Dvířka</span>
            <span class="spec-value" style="font-size:1.4rem">Trachea</span>
          </div>
          <div class="spec-item">
            <span class="spec-label">Zaměření</span>
            <span class="spec-value" style="font-size:1.4rem"><em>zdarma</em></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ REALIZACE — HORIZONTÁLNÍ SCROLL ═══════════════ -->
<section class="section-dark hscroll-section">
  <div class="container hscroll-head">
    <span class="eyebrow eyebrow--accent">04 · Poslední z dílny</span>
    <h2 class="display-mega">Kuchyně, které<br><em>promlouvají</em>.</h2>
  </div>

  <div class="hscroll-wrap">
    <button class="hscroll-side hscroll-side--prev" data-hscroll-prev aria-label="Předchozí">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <button class="hscroll-side hscroll-side--next" data-hscroll-next aria-label="Další">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </button>

    <div class="hscroll-track" data-hscroll>
      <% (featured || []).forEach(function(p, idx){ %>
        <a class="hscroll-card" href="/uploads/<%= p.filename %>" data-lightbox
           data-title="<%= p.title || '' %>" data-desc="<%= p.description || '' %>">
          <div class="hscroll-card-img">
            <img src="/uploads/<%= p.thumb_filename || p.filename %>" alt="<%= p.title || 'Realizace' %>" loading="lazy" />
          </div>
          <div class="hscroll-card-meta">
            <span class="hscroll-card-num"><%= String(idx + 1).padStart(2, '0') %></span>
            <div>
              <% if (p.cat_name) { %><span class="tag tag--accent"><%= p.cat_name %></span><% } %>
              <strong><%= p.title || 'Realizace' %></strong>
            </div>
          </div>
        </a>
      <% }); %>
      <a class="hscroll-card hscroll-card--last" href="/kuchyne">
        <div class="hscroll-card-img">
          <div class="hscroll-card-more"><span>Všechny<br>realizace →</span></div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════ 3D VIZUALIZACE ═══════════════ -->
<section class="section threedee-section">
  <div class="container">
    <div class="threedee-grid">
      <div class="threedee-visual">
        <img src="/uploads/real-04.jpg" alt="Kuchyň s ostrůvkem a masivní pracovní deskou" class="threedee-visual-img" />
        <div class="threedee-badge">
          <span class="threedee-badge-num">3D</span>
          <span class="threedee-badge-txt">vizualizace</span>
        </div>
        <div class="threedee-caption">Realizace, která začala 3D návrhem</div>
      </div>
      <div class="threedee-content">
        <span class="eyebrow">05 · Bonus zdarma</span>
        <h2 class="display-mega">Vaše kuchyň<br>ještě před<br><em>první</em> deskou.</h2>
        <p class="threedee-lead">Ke každé zakázce dostanete <strong>3D vizualizaci zdarma</strong>. Uvidíte, jak bude vypadat, ještě než začneme řezat první díl.</p>
        <ul class="threedee-list">
          <li><span class="threedee-check">✓</span>Realistický 3D model do 7 dní od zaměření</li>
          <li><span class="threedee-check">✓</span>Neomezené úpravy, dokud nebudete spokojení</li>
          <li><span class="threedee-check">✓</span>Zdarma i když si kuchyň nakonec nevezmete</li>
        </ul>
        <a href="/kontakt" class="btn btn--primary btn--lg">
          <span>Chci 3D návrh</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ BEFORE / AFTER ═══════════════ -->
<section class="section ba-section">
  <div class="container">
    <div class="section-head-mega section-head-center">
      <span class="eyebrow">06 · Který styl</span>
      <h2 class="display-mega">Světlá,<br>nebo <em>tmavá</em>?</h2>
      <p class="section-lead">Přetáhněte posuvník uprostřed. Dvě naše realizace. Kterou byste chtěli u sebe doma?</p>
    </div>

    <div class="ba-slider" data-ba-slider>
      <div class="ba-before">
        <img src="/uploads/real-05.jpg" alt="Světlá kuchyň" />
        <span class="ba-label ba-label--before">Světlá</span>
      </div>
      <div class="ba-after">
        <img src="/uploads/real-06.jpg" alt="Tmavá kuchyň" />
        <span class="ba-label ba-label--after">Tmavá</span>
      </div>
      <div class="ba-handle" data-ba-handle>
        <div class="ba-handle-circle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 3L4 7l4 4M16 21l4-4-4-4M4 7h16M20 17H4"/></svg>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ PROCES ═══════════════ -->
<section class="section-dark process-section">
  <div class="container">
    <div class="section-head-mega">
      <span class="eyebrow eyebrow--accent">07 · Jak spolupracujeme</span>
      <h2 class="display-mega">Šest kroků<br>k <em>hotové</em> kuchyni.</h2>
    </div>

    <div class="timeline">
      <div class="timeline-step" data-reveal>
        <div class="timeline-dot"><span>01</span></div>
        <div class="timeline-body">
          <h3>Konzultace</h3>
          <p>Zavolejte nebo napište. Probereme prostor, rozpočet, představu.</p>
          <span class="timeline-time">30 min</span>
        </div>
      </div>
      <div class="timeline-step" data-reveal>
        <div class="timeline-dot"><span>02</span></div>
        <div class="timeline-body">
          <h3>Zaměření</h3>
          <p>Přijedu k vám. Změříme na milimetry. Poradím s dispozicí, materiály, spotřebiči.</p>
          <span class="timeline-time">1–2 h</span>
        </div>
      </div>
      <div class="timeline-step" data-reveal>
        <div class="timeline-dot"><span>03</span></div>
        <div class="timeline-body">
          <h3>Návrh a 3D</h3>
          <p>Připravím půdorys, 3D vizualizaci a cenovou nabídku. Nezávazně.</p>
          <span class="timeline-time">7–10 dní</span>
        </div>
      </div>
      <div class="timeline-step" data-reveal>
        <div class="timeline-dot"><span>04</span></div>
        <div class="timeline-body">
          <h3>Výroba v dílně</h3>
          <p>V mé dílně v Olešníku vyrábím přesně to, co jste odsouhlasili.</p>
          <span class="timeline-time">6–10 týdnů</span>
        </div>
      </div>
      <div class="timeline-step" data-reveal>
        <div class="timeline-dot"><span>05</span></div>
        <div class="timeline-body">
          <h3>Montáž u vás</h3>
          <p>Precizní instalace, doladění, úklid. Předám čistou funkční kuchyni.</p>
          <span class="timeline-time">1–3 dny</span>
        </div>
      </div>
      <div class="timeline-step" data-reveal>
        <div class="timeline-dot"><span>06</span></div>
        <div class="timeline-body">
          <h3>Servis a záruka</h3>
          <p>Pět let záruka na výrobu. Blum kování doživotně. Servis dělám sám.</p>
          <span class="timeline-time">napořád</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════ RECENZE ═══════════════ -->
<section class="section testimonials-section">
  <div class="container">
    <div class="section-head-mega">
      <span class="eyebrow">08 · Co říkají klienti</span>
      <h2 class="display-mega">Kuchyň slouží roky.<br>Vzpomínka na <em>lidi</em>, kteří ji dělali, taky.</h2>
    </div>

    <div class="testimonials-grid">
      <blockquote class="testimonial" data-reveal>
        <span class="quote-mark">"</span>
        <p>Pan Čihovský nám dělal kuchyň před osmi lety. Nedávno jsem volal, že se uvolnil jeden pant. Přijel druhý den. To dnes nikdo nedělá.</p>
        <footer>
          <strong>Martin K.</strong>
          <span>České Budějovice · moderní kuchyň · 2016</span>
        </footer>
      </blockquote>
      <blockquote class="testimonial testimonial--featured" data-reveal>
        <span class="quote-mark">"</span>
        <p>Prošli jsme tři firmy, než jsme narazili na pana Čihovského. Jediný, který s námi seděl u kávy dvě hodiny a ptal se, jak vaříme. Zbytek nám ukazoval katalog.</p>
        <footer>
          <strong>Petra a Jan B.</strong>
          <span>Písek · rustikální kuchyň s ostrůvkem · 2023</span>
        </footer>
      </blockquote>
      <blockquote class="testimonial" data-reveal>
        <span class="quote-mark">"</span>
        <p>Chtěli jsme dubové dveře do celého domu. Objednali jsme se s vidinou, že to bude drahé. Cenově příjemné překvapení, kvalita nadstandardní.</p>
        <footer>
          <strong>Tomáš V.</strong>
          <span>Prachatice · dveře a šatna · 2024</span>
        </footer>
      </blockquote>
    </div>
  </div>
</section>

<!-- ═══════════════ CTA BANNER ═══════════════ -->
