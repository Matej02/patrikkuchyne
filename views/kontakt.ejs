<%- include('partials/head') %>
<body class="page-kontakt">
<%- include('partials/header') %>

<section class="page-hero-split">
  <div class="container page-hero-split-grid">
    <div class="page-hero-text">
      <span class="eyebrow">01 · Kontakt</span>
      <h1 class="display display--xl">Pojďme se<br>bavit o vaší<br><em>kuchyni</em>.</h1>
      <p class="page-lead">Vyplňte čtyři krátké kroky. Do jednoho pracovního dne se vám ozvu.</p>
      <div class="page-hero-meta">
        <a href="tel:+420608032103" class="page-hero-meta-item">
          <span class="mono">Volejte</span>
          <strong>+420 608 032 103</strong>
        </a>
        <a href="mailto:cihovsky@c-box.cz" class="page-hero-meta-item">
          <span class="mono">Pište</span>
          <strong>cihovsky@c-box.cz</strong>
        </a>
      </div>
    </div>
    <div class="page-hero-photo">
      <img src="/uploads/real-01.jpg" alt="" loading="lazy" />
      <div class="page-hero-photo-caption">
        <span class="mono">Realizace · Písek · 2024</span>
      </div>
    </div>
  </div>
</section>

<section class="section section--tight">
  <div class="container contact-grid">
    <div class="contact-info">
      <div class="info-block">
        <span class="eyebrow">Telefon</span>
        <a class="big-link" href="tel:<%= contact.phone.replace(/\s/g, '') %>"><%= contact.phone %></a>
      </div>
      <div class="info-block">
        <span class="eyebrow">E-mail</span>
        <a class="big-link" href="mailto:<%= contact.email %>"><%= contact.email %></a>
      </div>
      <div class="info-block">
        <span class="eyebrow">Dílna</span>
        <p class="muted"><%= contact.address %><br><%= contact.hours %></p>
      </div>
      <% if (contact.instagram || contact.facebook) { %>
        <div class="info-block">
          <span class="eyebrow">Sledujte nás</span>
          <div class="socials socials--dark">
            <% if (contact.instagram) { %>
              <a href="<%= contact.instagram %>" target="_blank" rel="noopener" aria-label="Instagram" class="social-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
            <% } %>
            <% if (contact.facebook) { %>
              <a href="<%= contact.facebook %>" target="_blank" rel="noopener" aria-label="Facebook" class="social-link">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.6-1.6h1.7V3.2C16.5 3.1 15.5 3 14.4 3c-2.4 0-4 1.5-4 4.2v2.6H7.7V13h2.7v8h3.1z"/></svg>
              </a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="contact-form-wrap">
      <% if (sent) { %>
        <div class="alert alert--success">
          <strong>Děkujeme, poptávku máme.</strong>
          <p>Ozveme se vám do jednoho pracovního dne. Mezitím koukněte na <a href="/kuchyne" style="text-decoration:underline">naše realizace</a> — možná najdete inspiraci.</p>
        </div>
      <% } else { %>
        <form class="wizard" method="POST" action="/kontakt" data-wizard>
          <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

          <div class="wizard-progress">
            <div class="wizard-progress-bar"><div class="wizard-progress-fill" data-progress-fill></div></div>
            <div class="wizard-steps-labels">
              <span class="wizard-step-label is-active" data-step-label="1">1 · Co plánujete</span>
              <span class="wizard-step-label" data-step-label="2">2 · Kdy</span>
              <span class="wizard-step-label" data-step-label="3">3 · Rozpočet</span>
              <span class="wizard-step-label" data-step-label="4">4 · Kontakt</span>
            </div>
          </div>

          <!-- KROK 1 — Co plánujete -->
          <fieldset class="wizard-step is-active" data-step="1">
            <legend class="wizard-legend">
              <span class="wizard-legend-num">01</span>
              Co pro vás máme vyrobit?
            </legend>
            <div class="wizard-choices">
              <label class="wizard-choice">
                <input type="radio" name="plan" value="Kuchyň na míru" required>
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Kuchyň na míru</span>
                  <span class="wizard-choice-desc">Kompletní kuchyň včetně spotřebičů a montáže</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="plan" value="Dveře">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Dveře na míru</span>
                  <span class="wizard-choice-desc">Interiérové, posuvné, prosklené — do celého bytu</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="plan" value="Vestavěné skříně">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Vestavěné skříně</span>
                  <span class="wizard-choice-desc">Šatny, úložné prostory, garderoby</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="plan" value="Nábytek na míru">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Nábytek na míru</span>
                  <span class="wizard-choice-desc">Knihovny, komody, dětské pokoje</span>
                </span>
              </label>
              <label class="wizard-choice wizard-choice--wide">
                <input type="radio" name="plan" value="Ještě nejsem rozhodnutý">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Ještě nejsem rozhodnutý</span>
                  <span class="wizard-choice-desc">Rád si popovídám o možnostech</span>
                </span>
              </label>
            </div>
            <div class="wizard-actions">
              <span></span>
              <button type="button" class="btn btn--primary" data-wizard-next>Pokračovat →</button>
            </div>
          </fieldset>

          <!-- KROK 2 — Kdy -->
          <fieldset class="wizard-step" data-step="2">
            <legend class="wizard-legend">
              <span class="wizard-legend-num">02</span>
              Kdy s tím chcete začít?
            </legend>
            <div class="wizard-choices">
              <label class="wizard-choice">
                <input type="radio" name="term" value="Co nejdřív" required>
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Co nejdřív</span>
                  <span class="wizard-choice-desc">Rozhodnutí padlo, jde se stavět</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="term" value="Do 3 měsíců">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Do 3 měsíců</span>
                  <span class="wizard-choice-desc">Máme čas na návrh a přípravu</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="term" value="Do půl roku">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Do půl roku</span>
                  <span class="wizard-choice-desc">Sbíráme informace, plánujeme</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="term" value="Zatím se rozkoukávám">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Zatím se rozkoukávám</span>
                  <span class="wizard-choice-desc">Zjišťuji možnosti a ceny</span>
                </span>
              </label>
            </div>
            <div class="wizard-actions">
              <button type="button" class="btn btn--ghost btn--dark" data-wizard-prev>← Zpět</button>
              <button type="button" class="btn btn--primary" data-wizard-next>Pokračovat →</button>
            </div>
          </fieldset>

          <!-- KROK 3 — Rozpočet -->
          <fieldset class="wizard-step" data-step="3">
            <legend class="wizard-legend">
              <span class="wizard-legend-num">03</span>
              Jaký rozpočet zvažujete?
            </legend>
            <p class="wizard-hint">Nemusíte to teď řešit — pomůže nám to jen navrhnout materiály přiměřené vašim představám.</p>
            <div class="wizard-choices">
              <label class="wizard-choice">
                <input type="radio" name="budget" value="do 100 000 Kč" required>
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">do 100 000 Kč</span>
                  <span class="wizard-choice-desc">Základní varianta</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="budget" value="100 000 – 250 000 Kč">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">100 000 – 250 000 Kč</span>
                  <span class="wizard-choice-desc">Střední třída, kvalitní materiály</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="budget" value="250 000 – 500 000 Kč">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">250 000 – 500 000 Kč</span>
                  <span class="wizard-choice-desc">Prémiové materiály, kámen, spotřebiče</span>
                </span>
              </label>
              <label class="wizard-choice">
                <input type="radio" name="budget" value="500 000 Kč a více">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">500 000 Kč a více</span>
                  <span class="wizard-choice-desc">Nadstandard, masiv, jedinečné řešení</span>
                </span>
              </label>
              <label class="wizard-choice wizard-choice--wide">
                <input type="radio" name="budget" value="Nechte mě poradit">
                <span class="wizard-choice-box">
                  <span class="wizard-choice-title">Nevím, poraďte mi</span>
                  <span class="wizard-choice-desc">Domluvíme se podle rozsahu prací</span>
                </span>
              </label>
            </div>
            <div class="wizard-actions">
              <button type="button" class="btn btn--ghost btn--dark" data-wizard-prev>← Zpět</button>
              <button type="button" class="btn btn--primary" data-wizard-next>Pokračovat →</button>
            </div>
          </fieldset>

          <!-- KROK 4 — Kontakt -->
          <fieldset class="wizard-step" data-step="4">
            <legend class="wizard-legend">
              <span class="wizard-legend-num">04</span>
              Jak vám máme odpovědět?
            </legend>
            <div class="wizard-fields">
              <label class="wizard-field">
                <span>Jméno *</span>
                <input type="text" name="name" required autocomplete="name" />
              </label>
              <label class="wizard-field">
                <span>E-mail *</span>
                <input type="email" name="email" required autocomplete="email" />
              </label>
              <label class="wizard-field">
                <span>Telefon</span>
                <input type="tel" name="phone" autocomplete="tel" />
              </label>
              <label class="wizard-field wizard-field--wide">
                <span>Něco navíc? (nepovinné)</span>
                <textarea name="message" rows="4" placeholder="Rozměry prostoru, styl, který se vám líbí, cokoliv, co byste chtěl(a) sdělit."></textarea>
              </label>
            </div>
            <input type="text" name="website" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" aria-hidden="true" />
            <div class="wizard-summary" data-wizard-summary></div>
            <div class="wizard-actions">
              <button type="button" class="btn btn--ghost btn--dark" data-wizard-prev>← Zpět</button>
              <button type="submit" class="btn btn--primary btn--lg">Odeslat poptávku →</button>
            </div>
          </fieldset>
        </form>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
