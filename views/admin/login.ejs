<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Kuchyně Čihovský</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="login-body">
  <div class="login-card">
    <div class="login-brand">
      <span class="brand-mark">C</span>
      <div>
        <strong>Čihovský</strong>
        <small>administrace</small>
      </div>
    </div>
    <h1>Přihlášení</h1>
    <p class="muted">Vstup pro správu fotogalerie a webu.</p>

    <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>

    <form method="POST" action="/admin/login" class="login-form">
      <label>
        <span>Přihlašovací jméno</span>
        <input type="text" name="username" required autofocus />
      </label>
      <label>
        <span>Heslo</span>
        <input type="password" name="password" required />
      </label>
      <button type="submit" class="btn btn--primary btn--lg btn--block">Přihlásit se</button>
    </form>

    <a href="/" class="login-back">← zpět na web</a>
  </div>
</body>
</html>
