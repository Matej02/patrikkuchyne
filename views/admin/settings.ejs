<%- include('_layout-start') %>

<header class="admin-header">
  <div>
    <span class="admin-eyebrow">Účet</span>
    <h1>Nastavení</h1>
  </div>
</header>

<div class="admin-panel admin-panel--narrow">
  <h2>Změnit heslo</h2>
  <% if (success) { %><div class="alert alert--success"><%= success %></div><% } %>
  <% if (error) { %><div class="alert alert--error"><%= error %></div><% } %>
  <form method="POST" action="/admin/nastaveni/heslo" class="admin-form">
    <label><span>Současné heslo</span><input type="password" name="current" required /></label>
    <label><span>Nové heslo (min. 8 znaků)</span><input type="password" name="next" required minlength="8" /></label>
    <label><span>Nové heslo znovu</span><input type="password" name="confirm" required minlength="8" /></label>
    <button type="submit" class="btn btn--primary">Změnit heslo</button>
  </form>
</div>

<%- include('_layout-end') %>
